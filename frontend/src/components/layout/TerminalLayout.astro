---
// TerminalLayout.astro
interface Props {
    title?: string;
    children: any;
}

const { title = "Arz.Dev | Terminal de Activos", children } = Astro.props;
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <title>{title}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/date-fns@2.30.0/dist/date-fns.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    </head>
    <body class="bg-[#050505] text-zinc-100 font-['Inter'] antialiased selection:bg-cyan-500/30">
        <div class="fixed inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-cyan-900/10 via-transparent to-transparent -z-10"></div>
        <main class="max-w-7xl mx-auto px-6 py-12">
            {children}
        </main>
    </body>
</html>