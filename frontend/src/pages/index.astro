---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Layout from "../layouts/Layout.astro";

interface PriceEntry {
    price: number;
    timestamp: number;
}

interface CoinData {
    usd: number;
    change_24h: number;
    high_24h: number;
    low_24h: number;
    market_cap: number;
    total_volume: number;
    history: PriceEntry[];
}

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";
let prices: Record<string, CoinData> = {};
let error = null;

try {
    const response = await fetch(`${API_URL}/api/prices`);
    if (response.ok) {
        prices = await response.json();
    } else {
        error = "Sincronizando nodo principal...";
    }
} catch (e) {
    error = "Buscando señal de mercado...";
}

const defaultCoin = Object.keys(prices)[0] || "bitcoin";
---

<Layout>
    <div class="fixed inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-cyan-900/10 via-transparent to-transparent -z-10"></div>

    <main class="max-w-7xl mx-auto px-4 md:px-6 py-4 md:py-12 h-auto md:h-screen flex flex-col md:overflow-hidden">
        
        <!-- Header -->
        <Header class="shrink-0" />

        {
            error ? (
                <div class="h-96 flex items-center justify-center border border-zinc-800/50 rounded-xl bg-[#0a0a0a]">
                    <p class="text-zinc-500 text-xs uppercase tracking-[0.3em] animate-pulse">
                        {error}
                    </p>
                </div>
            ) : (
                <div class="grid grid-cols-1 xl:grid-cols-4 gap-6 flex-1 min-h-0">
                    <div class="xl:col-span-3 bg-[#0d0d0d] border border-zinc-800/50 p-6 md:p-8 rounded-xl relative overflow-hidden flex flex-col min-h-0">
                        <div class="absolute -inset-px bg-gradient-to-br from-cyan-500/5 to-transparent opacity-50"></div>

                        <div class="relative z-10 h-full flex flex-col">
                            
                            <div class="flex justify-between items-start mb-6">
                                <div>
                                    <h2 id="main-coin-name" class="text-zinc-400 text-xs uppercase tracking-[0.3em] font-bold mb-2">
                                        {defaultCoin} / USD
                                    </h2>

                                    <p id="main-coin-price" class="text-4xl md:text-6xl font-light tracking-tighter leading-none">
                                        <span class="text-zinc-600 text-xl md:text-3xl">$</span>
                                        {new Intl.NumberFormat("en-US", {
                                            minimumFractionDigits: prices[defaultCoin]?.usd < 1 ? 4 : 2,
                                            maximumFractionDigits: prices[defaultCoin]?.usd < 1 ? 4 : 2,
                                        }).format(prices[defaultCoin]?.usd)}
                                    </p>

                                    <p class="text-[10px] text-zinc-600 uppercase tracking-tight mt-1">
                                        Real-time USD Price
                                    </p>
                                </div>

                                <div
                                    id="main-coin-change"
                                    class={`text-sm font-mono p-2 rounded ${
                                        prices[defaultCoin]?.change_24h >= 0
                                            ? "bg-green-500/10 text-green-400"
                                            : "bg-red-500/10 text-red-400"
                                    }`}
                                >
                                    {prices[defaultCoin]?.change_24h >= 0 ? "▲" : "▼"}{" "}
                                    {Math.abs(prices[defaultCoin]?.change_24h).toFixed(2)}%
                                </div>
                            </div>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6 md:mb-8 pt-6 border-t border-zinc-800/60">
                                <div>
                                    <p class="text-[9px] text-zinc-600 uppercase mb-1">Market Cap</p>
                                    <p class="text-xs font-mono text-zinc-400">
                                        ${prices[defaultCoin]?.market_cap
                                            ? (prices[defaultCoin].market_cap / 1e9).toFixed(2) + "B"
                                            : "—"}
                                    </p>
                                </div>

                                <div>
                                    <p class="text-[9px] text-zinc-600 uppercase mb-1">Vol. 24h</p>
                                    <p class="text-xs font-mono text-zinc-400">
                                        ${prices[defaultCoin]?.total_volume
                                            ? (prices[defaultCoin].total_volume / 1e9).toFixed(2) + "B"
                                            : "—"}
                                    </p>
                                </div>
                                <div>
                                    <p class="text-[9px] text-zinc-600 uppercase mb-1">High 24h</p>
                                    <p class="text-xs font-mono text-zinc-400">
                                        ${prices[defaultCoin]?.high_24h
                                            ? new Intl.NumberFormat("en-US", {
                                                  minimumFractionDigits: 2,
                                                  maximumFractionDigits: 2,
                                              }).format(prices[defaultCoin].high_24h)
                                            : "—"}
                                    </p>
                                </div>
                                <div>
                                    <p class="text-[9px] text-zinc-600 uppercase mb-1">Low 24h</p>
                                    <p class="text-xs font-mono text-zinc-400">
                                        ${prices[defaultCoin]?.low_24h
                                            ? new Intl.NumberFormat("en-US", {
                                                  minimumFractionDigits: 2,
                                                  maximumFractionDigits: 2,
                                              }).format(prices[defaultCoin].low_24h)
                                            : "—"}
                                    </p>
                                </div>
                            </div>
                            <div class="flex-1 min-h-[250px] md:min-h-0">
                                <canvas id="main-chart"></canvas>
                            </div>
                            <div class="flex items-center gap-2 mt-4">
                                <div class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></div>
                                <p class="text-[9px] text-zinc-600 uppercase">
                                    Actualizando en tiempo real
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="space-y-3 md:overflow-y-auto md:min-h-0">
                        <h3 class="text-zinc-600 text-[10px] uppercase tracking-[0.3em] font-bold pl-2 mb-4">
                            Activos Disponibles
                        </h3>

                        {Object.entries(prices).map(([name, data]) => (
                            <button
                                class="coin-selector cursor-pointer w-full text-left bg-[#0d0d0d] border border-zinc-800/50 p-4 md:p-5 rounded-xl hover:border-cyan-500/30 transition"
                                data-coin={name}
                                data-price={data.usd}
                                data-change={data.change_24h}
                                data-high={data.high_24h}
                                data-low={data.low_24h}
                                data-cap={data.market_cap}
                                data-vol={data.total_volume}
                                data-history={JSON.stringify(data.history)}
                            >
                                <div class="flex justify-between items-center">
                                    <div>
                                        <span class="text-zinc-400 text-[10px] uppercase block mb-1">
                                            {name}
                                        </span>

                                        <p class="text-lg md:text-xl font-light">
                                            ${new Intl.NumberFormat("en-US", {
                                                minimumFractionDigits: data.usd < 1 ? 4 : 2,
                                                maximumFractionDigits: data.usd < 1 ? 4 : 2,
                                            }).format(data.usd)}
                                        </p>
                                    </div>

                                    <span
                                        class={`text-[10px] font-mono ${
                                            data.change_24h >= 0 ? "text-green-500" : "text-red-500"
                                        }`}
                                    >
                                        {data.change_24h >= 0 ? "▲" : "▼"}{" "}
                                        {Math.abs(data.change_24h).toFixed(2)}%
                                    </span>
                                </div>
                            </button>
                        ))}
                    </div>
                </div>
            )
        }
        <Footer class="shrink-0" />
    </main>
</Layout>